#Equations for connectivity
import pandas as pd

data = pd.read_excel('Stand_Data_Updated.xlsx')
output_file_path = "November_Sajal_New_connectivity_equations.txt"

periods = [1, 2, 3, 4, 5]
with open(output_file_path, 'w') as file:
    con_index = 1
    data['ug'] = data['ug'].astype(int)
    data['ug_adj'] = data['ug_adj'].astype(int)
    unique_ug = data['ug'].unique()
    for period in periods:
        for ug in unique_ug:
            adjacent_stands = data[data['ug'] == ug]['ug_adj'].unique()
            sum_expression = ' + '.join([f"F{int(adj)}_1_{int(period)}" for adj in adjacent_stands])
            equation = f"Con_{con_index}: {sum_expression} - F{int(ug)}_1_{int(period)} >= 0"
            file.write(equation + '\n')
            con_index += 1

