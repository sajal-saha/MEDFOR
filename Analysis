# Creating Fuel Treatment Area Constraint (Min and Max Limit)
import pandas as pd

data = pd.read_excel('November_New_stand_area.xlsx')
periods = [1, 2, 3, 4, 5]
output_file_path = "November_New_Sajal_equations_max_min_area.txt"

with open(output_file_path, 'w') as file:
    ac_index_max = 1
    ac_index_min = 1
    data['ug'] = data['ug'].astype(int)

    for period in periods:
        sum_expression_max = ' + '.join([f"{row['area']} F{int(row['ug'])}_1_{int(period)}"
                                         for index, row in data.iterrows()])
        equation_max = f"AC{ac_index_max}: {sum_expression_max} - Max_Area <= 0"
        file.write(equation_max + '\n')
        ac_index_max += 1

    for period in periods:     
        sum_expression_min = ' + '.join([f"{row['area']} F{int(row['ug'])}_1_{int(period)}"
                                         for index, row in data.iterrows()])
        equation_min = f"AC{ac_index_min}: {sum_expression_min} - Min_Area >= 0"
        file.write(equation_min + '\n')
        ac_index_min += 1

#Equation that relate Yvar (Harvesting) and Fvar (Fuel Treatment)
import pandas as pd
data = pd.read_excel('Stand_Data_Updated.xlsx')
output_file_path = "November_Sajal_equations_output.txt"
binary_variable_file_path = "November_Sajal_binary_variables.txt"

binary_variables = set() # As we needd to have list of binary variables to be inclded in the LP file

periods = [1, 2, 3, 4, 5]
with open(output_file_path, 'w') as file:
    pfb_index = 1
    data['ug'] = data['ug'].astype(int)
    data['ug_adj'] = data['ug_adj'].astype(int)
    unique_ug = data['ug'].unique()
    for period in periods:
        for ug in unique_ug:
            equation = f"PFB{pfb_index}: Y{int(ug)}_{int(period)} - F{int(ug)}_1_{int(period)} = 0"
            file.write(equation + '\n')
            pfb_index += 1
            binary_variables.add(f"Y{int(ug)}_{int(period)}")
            binary_variables.add(f"F{int(ug)}_1_{int(period)}")
with open(binary_variable_file_path, 'w') as var_file:
    for var in sorted(binary_variables):
        var_file.write(var + '\n')

